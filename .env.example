# Copy this file to .env and fill in your details

# Gmail SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# AWS Configuration (If running locally instead of EC2 Instance Profile)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_DEFAULT_REGION=ap-south-1
# S3_BUCKET_NAME=chatbox-profile-pictures

# Free LLM for PDF summaries (Groq — https://console.groq.com/keys)
# GROQ_API_KEY=gsk_...
# Optional: GROQ_MODEL=llama-3.1-8b-instant

# Optional: HTTPS URL for email banner image (e.g. S3 public object). If unset, a built-in PNG is embedded.
# EMAIL_HEADER_IMAGE_URL=https://your-bucket.s3.ap-south-1.amazonaws.com/email/banner.png
# Optional: path to a .ttf for the banner (servers without fonts)
# EMAIL_BANNER_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf

# Streamlit client (Mac / local) — point at your EC2 FastAPI host
# CHATBOX_API_BASE=http://YOUR_EC2_PUBLIC_IP:8000
# CHATBOX_WS_BASE=ws://YOUR_EC2_PUBLIC_IP:8000
